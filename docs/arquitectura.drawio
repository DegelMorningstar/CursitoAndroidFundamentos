        <mxCell id="pRoot" value="Contenedor con estado&#10;(obtiene la lógica de pantalla y observa el estado)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
