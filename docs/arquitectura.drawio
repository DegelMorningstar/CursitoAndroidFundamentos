        <mxCell id="pData" value="Fuente de datos (nube / local)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="390" y="640" width="200" height="45" as="geometry" />
        </mxCell>

        <mxCell id="note" value="Flujo unidireccional:&#10;los eventos suben, el estado baja." style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;size=14;" vertex="1" parent="1">
          <mxGeometry x="720" y="380" width="220" height="70" as="geometry" />
        </mxCell>

        <!-- Edges -->
